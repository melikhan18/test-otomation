# ─────────────────────────────────────────────────────────────────────────────
# Device Platform — Environment variables
#
# This file is the schema. Copy it to `.env` (which is gitignored) and fill in
# real values for your environment. `.env` is read automatically by
# `docker compose up`.
#
# For production:
#   1. Generate fresh secrets:
#        JWT_SECRET=$(openssl rand -base64 64 | tr -d '\n')
#        POSTGRES_PASSWORD=$(openssl rand -base64 24 | tr -d '\n' | tr -d '/+=')
#        MINIO_ROOT_PASSWORD=$(openssl rand -base64 24 | tr -d '\n' | tr -d '/+=')
#        ADMIN_PASSWORD=$(openssl rand -base64 16 | tr -d '\n' | tr -d '/+=')
#   2. Set CORS_ALLOWED_ORIGINS + MINIO_PUBLIC_URL to your real domain.
#   3. Never commit the resulting `.env` to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets ──────────────────────────────────────────────────────────────────

# JWT signing secret. MUST be a base64-encoded value of at least 64 bytes (raw).
# Anyone who knows this can forge any token in the system.
JWT_SECRET=change-me-base64-64-bytes-or-more

# Postgres credentials. The DB is exposed on port 5432 by default — bind it to
# 127.0.0.1 (DB_BIND below) in production so nothing on the public internet
# can attempt password auth against it.
POSTGRES_USER=dp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=device_platform

# MinIO root credentials. Used by every service to push/pull screenshots & videos.
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me-strong-password

# Initial admin account created on first auth-service boot.
# (Skipped if the username already exists, so rotating this here doesn't change
# the live password — use the API or DB to update the existing user.)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# ── Public URLs ──────────────────────────────────────────────────────────────

# Origins allowed to call the API from a browser. Comma-separated, no spaces.
# Use exact origins in prod (no wildcards). Examples:
#   CORS_ALLOWED_ORIGINS=https://console.example.com
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# MinIO public URL — the address the browser uses to fetch screenshots/videos.
# In dev this is the host's mapped port. In prod this should be your TLS-fronted
# media domain, e.g. https://media.example.com or https://example.com/minio
MINIO_PUBLIC_URL=http://localhost:9000

# Public WS URL that the Android agent connects to. Returned to the agent in
# enrollment responses; the agent uses it verbatim.
#   dev   : ws://10.0.2.2:8080/ws/agent  (Android emulator → host)
#   prod  : wss://example.com/ws/agent
APP_BRIDGE_PUBLIC_WS_URL=ws://localhost:8080/ws/agent

# ── Bind addresses (prod hardening) ──────────────────────────────────────────
#
# By default Docker binds these ports to 0.0.0.0 — meaning postgres, redis,
# minio, and every internal service are reachable from the public internet on
# the host. In production, set the *_BIND vars to `127.0.0.1` so only the host
# (and the nginx reverse proxy on it) can reach them. Only the gateway needs
# to be world-reachable (and even that goes via nginx in prod, so 127.0.0.1
# is the right choice for it too).
#
# Leave blank or set to empty for the docker default (0.0.0.0).

POSTGRES_BIND=127.0.0.1
REDIS_BIND=127.0.0.1
MINIO_BIND=127.0.0.1
GATEWAY_BIND=127.0.0.1

# Internal backend services normally don't need host port mappings at all in
# prod (gateway reaches them via the compose network). Setting these to
# 127.0.0.1 keeps them debuggable from the host while hiding them from the
# internet.
AUTH_BIND=127.0.0.1
DEVICE_BIND=127.0.0.1
SESSION_BIND=127.0.0.1
BRIDGE_BIND=127.0.0.1
AUTOMATION_BIND=127.0.0.1

# ── Retention ────────────────────────────────────────────────────────────────

# How long to keep run videos / screenshots in MinIO. Cron is Spring's 6-field
# format (sec min hour day month dow). Default: every day at 03:00.
RETENTION_ENABLED=true
RETENTION_DAYS=30
RETENTION_CRON=0 0 3 * * *
